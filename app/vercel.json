{
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest/agendar/:slug.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "sentinelagendamentos.com"
        }
      ],
      "destination": "https://www.sentinelagendamentos.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/c/:token",
      "destination": "https://zdmecbyyfubpmwrzzbqf.supabase.co/functions/v1/confirm-appointment-og?token=:token"
    },
    {
      "source": "/confirmar-agendamento/:token",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|WhatsApp|whatsapp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Pinterest).*"
        }
      ],
      "destination": "https://zdmecbyyfubpmwrzzbqf.supabase.co/functions/v1/confirm-appointment-og?token=:token"
    },
    {
      "source": "/manifest/agendar/:slug.webmanifest",
      "destination": "https://zdmecbyyfubpmwrzzbqf.supabase.co/functions/v1/client-pwa-manifest?slug=:slug"
    },
    {
      "source": "/manifest/agendar/:slug/icon-:size.png",
      "destination": "https://zdmecbyyfubpmwrzzbqf.supabase.co/functions/v1/client-pwa-icon?slug=:slug&size=:size"
    },
    {
      "source": "/((?!api/)(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
