# Copie para .env e preencha (o arquivo .env não vai para o Git)

# Supabase (frontend)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Web Push (chave pública VAPID — mesma do secret VAPID_PUBLIC_KEY no Supabase)
VITE_VAPID_PUBLIC_KEY=

# Mercado Pago — checkout agendamentos (chave pública de TESTE no dev)
VITE_MP_PUBLIC_KEY=TEST-...

# Stripe — assinatura Sentinela (cartão Start/Pro)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase Edge Functions (secrets no painel Supabase, NÃO no frontend)
# MP_ACCESS_TOKEN=              # Conta MP da PLATAFORMA (Pix assinatura). NÃO é OAuth do profissional.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_START=price_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_USAGE_METER_EVENT_NAME=rsc_confirmacao_de_agendamento  # futuro: cobrança por uso RSC
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+551199999999          # número aprovado na Twilio (WhatsApp Business)
# TWILIO_WEBHOOK_URL=https://<project>.functions.supabase.co/twilio-whatsapp-webhook  # URL exata cadastrada na Twilio (validação de assinatura)
# TWILIO_CONTENT_SID_REMINDER=HX...                     # Content Template do lembrete D-1 (botões Confirmar/Alterar/Cancelar)
# TWILIO_CONTENT_SID_PROFESSIONAL_ALERT=HX...           # Content Template do alerta ao profissional (cancelamento/alteração)
# TWILIO_OUTBOUND_BATCH_SIZE=10                         # Rate limit outbound: mensagens por lote (default 10)
# TWILIO_OUTBOUND_DELAY_MS=500                          # Rate limit outbound: pausa entre lotes em ms (default 500)
# REMINDER_CRON_SECRET=                                 # Secret compartilhado: pg_cron → process-appointment-reminders / process-whatsapp-webhook-jobs (obrigatório em produção)
# MP_CLIENT_ID=                 # OAuth app agendamentos (conta MP de cada profissional — só pagamentos de clientes)
# MP_CLIENT_SECRET=             # OAuth app agendamentos — NUNCA no frontend
# MP_APPOINTMENTS_OAUTH_TEST_MODE=true   # opcional: força test_token na troca OAuth
# APP_URL=https://sentinelagendamentos.com   # também usado pelos links da extensão Sentinela Connect
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:suporte@sentinelagendamentos.com
