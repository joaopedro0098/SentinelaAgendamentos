# Copie para .env e preencha (o arquivo .env não vai para o Git)

# Supabase (frontend)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Stripe — cartão recorrente (chave pública no frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Web Push (chave pública VAPID — mesma do secret VAPID_PUBLIC_KEY no Supabase)
VITE_VAPID_PUBLIC_KEY=

# Supabase Edge Functions (secrets no painel Supabase, NÃO no frontend)
# MP_ACCESS_TOKEN=          # Pix (Mercado Pago)
# STRIPE_SECRET_KEY=sk_...  # Cartão recorrente
# STRIPE_PRICE_ID=price_... # Preço mensal criado no Stripe Dashboard
# STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=https://sentinelagendamentos.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:suporte@sentinelagendamentos.com
