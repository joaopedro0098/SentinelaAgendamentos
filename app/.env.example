# Copie para .env e preencha (o arquivo .env não vai para o Git)

# Supabase (frontend)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Stripe — cartão recorrente (chave pública no frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Web Push (chave pública VAPID — mesma do secret VAPID_PUBLIC_KEY no Supabase)
VITE_VAPID_PUBLIC_KEY=

# Mercado Pago — checkout agendamentos (chave pública de TESTE no dev)
VITE_MP_PUBLIC_KEY=TEST-...

# Mercado Pago — assinatura Sentinela (cartão/Pix do plano). Mesma conta/aplicação do MP_ACCESS_TOKEN.
# Se omitido, usa VITE_MP_PUBLIC_KEY (só funciona se for a chave da plataforma, não só do OAuth de agendamentos).
VITE_MP_PLATFORM_PUBLIC_KEY=TEST-...

# Supabase Edge Functions (secrets no painel Supabase, NÃO no frontend)
# MP_ACCESS_TOKEN=              # Conta MP da PLATAFORMA (Pix assinatura + preapproval). NÃO é OAuth do profissional.
# MP_PREAPPROVAL_PLAN_ID=        # Plano de assinatura (preapproval_plan_id) no MP da plataforma
# MP_PREAPPROVAL_PLAN_ID_39=     # opcional: tier R$ 39
# MP_PREAPPROVAL_PLAN_ID_49=     # opcional: tier R$ 49
# MP_CLIENT_ID=                 # OAuth app agendamentos (conta MP de cada profissional — só pagamentos de clientes)
# MP_CLIENT_SECRET=             # OAuth app agendamentos — NUNCA no frontend
# MP_APPOINTMENTS_OAUTH_TEST_MODE=true   # opcional: força test_token na troca OAuth
# STRIPE_SECRET_KEY=sk_...  # Cartão recorrente
# STRIPE_PRICE_ID=price_... # Preço mensal criado no Stripe Dashboard
# STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=https://sentinelagendamentos.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:suporte@sentinelagendamentos.com
